# Copy to .env and adjust for local/Docker runs.
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Shared secret for service-to-service internal HTTP calls (Patient/Doctor internal routes)
INTERNAL_SERVICE_TOKEN=hospital-internal-token-change-me

# URLs used inside Docker network (do not use localhost between containers)
AUTH_SERVICE_URL=http://auth-service:8001
PATIENT_SERVICE_URL=http://patient-service:8002
DOCTOR_SERVICE_URL=http://doctor-service:8003
APPOINTMENT_SERVICE_URL=http://appointment-service:8004

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=hospital.events

# API Gateway
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_DOWNSTREAM_TIMEOUT_SECONDS=10

# SQLite paths inside containers (default)
AUTH_DATABASE_URL=sqlite+aiosqlite:////data/auth.db
PATIENT_DATABASE_URL=sqlite+aiosqlite:////data/patient.db
DOCTOR_DATABASE_URL=sqlite+aiosqlite:////data/doctor.db
APPOINTMENT_DATABASE_URL=sqlite+aiosqlite:////data/appointment.db
